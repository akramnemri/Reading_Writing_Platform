@model List<Novel>
@{
    ViewData["Title"] = "Review Queue";
}

<div class="container-fluid">
    @if (TempData["SuccessMessage"] != null)

    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)

    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <h1 class="mb-4">Review Queue</h1>

    <!-- Status Filter Pills -->
    <div class="mb-4">
        <div class="btn-group" role="group">
            <a asp-action="Index"
               asp-route-status=""
               asp-route-themeId="@Context.Request.Query["themeId"]"
               asp-route-authorId="@Context.Request.Query["authorId"]"
               asp-route-search="@Context.Request.Query["search"]"
               class="btn btn-outline-primary @(string.IsNullOrEmpty(Context.Request.Query["status"]) ? "active" : "")">
                All (@ViewBag.TotalAll)
            </a>
            <a asp-action="Index"
               asp-route-status="Submitted"
               asp-route-themeId="@Context.Request.Query["themeId"]"
               asp-route-authorId="@Context.Request.Query["authorId"]"
               asp-route-search="@Context.Request.Query["search"]"
               class="btn btn-outline-primary @(Context.Request.Query["status"] == "Submitted" ? "active" : "")">
                Pending (@ViewBag.SubmittedCount)
            </a>
            <a asp-action="Index"
               asp-route-status="Rejected"
               asp-route-themeId="@Context.Request.Query["themeId"]"
               asp-route-authorId="@Context.Request.Query["authorId"]"
               asp-route-search="@Context.Request.Query["search"]"
               class="btn btn-outline-primary @(Context.Request.Query["status"] == "Rejected" ? "active" : "")">
                Rejected (@ViewBag.RejectedCount)
            </a>
            <a asp-action="Index"
               asp-route-status="Approved"
               asp-route-themeId="@Context.Request.Query["themeId"]"
               asp-route-authorId="@Context.Request.Query["authorId"]"
               asp-route-search="@Context.Request.Query["search"]"
               class="btn btn-outline-primary @(Context.Request.Query["status"] == "Approved" ? "active" : "")">
                Approved (@ViewBag.ApprovedCount)
            </a>
        </div>
    </div>

    <!-- Filters Card (Theme, Author, Search) -->
    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <form method="get" class="row g-3">
                <input type="hidden" name="status" value="@Context.Request.Query["status"]" />
                <div class="col-md-3">
                    <label class="form-label fw-bold">Theme</label>
                    <select name="themeId" class="form-select" asp-items="ViewBag.Themes">
                        <option value="">All Themes</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">Author</label>
                    <select name="authorId" class="form-select" asp-items="ViewBag.Authors">
                        <option value="">All Authors</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold">Search</label>
                    <input type="text" name="search" class="form-control" value="@ViewBag.CurrentSearch"
                           placeholder="Title or author..." />
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary me-2">Filter</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
                </div>
            </form>
        </div>
    </div>

    <div class="mb-3">
        <span class="text-muted">@ViewBag.TotalItems novels pending review</span>
    </div>

    <!-- Card Grid -->
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4">
        @foreach (var novel in Model)

        {
            <div class="col">
                <div class="card h-100 shadow-sm @(novel.Status == NovelStatus.Rejected ? "border-warning border-2" : "border-primary border-2")">
                    @if (!string.IsNullOrEmpty(novel.CoverImageUrl))
                    {
                        <img src="@novel.CoverImageUrl" class="card-img-top" alt="@novel.Title"
                             style="height: 220px; object-fit: cover;" />
                    }
                    else
                    {
                        <div class="card-img-top bg-light d-flex align-items-center justify-content-center"
                             style="height: 220px;">
                            <span class="text-muted fs-1">No Cover</span>
                        </div>
                    }

                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title mb-0 text-truncate" style="max-width: 70%;" title="@novel.Title">
                                @novel.Title
                            </h5>
                            @if (novel.Status == NovelStatus.Rejected)
                            {
                                <span class="badge bg-warning text-dark">@($"Rejected (x{novel.SubmissionCount})")</span>
                            }
                            else if (novel.Status == NovelStatus.Submitted)
                            {
                                <span class="badge bg-primary">@($"Submitted (x{novel.SubmissionCount})")</span>
                            }
                            else if (novel.Status == NovelStatus.Approved)
                            {
                                <span class="badge bg-success">Approved</span>
                            }
                        </div>

                        <p class="card-text text-muted mb-1">
                            <small>by @(novel.AuthorUser?.UserName ?? "Unknown")</small>
                        </p>

                        <p class="card-text">
                            <small class="text-muted">
                                Submitted: @if (novel.SubmittedForReviewAt.HasValue)
                                {
                                    @novel.SubmittedForReviewAt.Value.ToString("MMM dd, yyyy")
                                }
                                else
                                {
                                    <text>N/A</text>
                                }
                            </small>
                        </p>

                        <p class="card-text small text-secondary" style="min-height: 3em;">
                            @(novel.Description?.Length > 120 ? novel.Description[..120] + "..." : novel.Description)
                        </p>

                        @if (novel.NovelThemes.Any())

                        {
                            <div class="mb-2">
                                @foreach (var nt in novel.NovelThemes.Take(3))

                                {
                                    <span class="badge bg-light text-dark border me-1">@(nt.Theme?.Name ?? "Unknown")</span>
                                }
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(novel.RejectionReason))

                        {
                            <div class="alert alert-warning py-1 px-2 small mb-0">
                                <strong>Prev:</strong> @novel.RejectionReason[..Math.Min(40, novel.RejectionReason.Length)]...
                            </div>
                        }
                    </div>

                    <div class="card-footer bg-transparent border-top-0">
                        <a asp-action="Details" asp-route-id="@novel.Id" class="btn btn-primary w-100">
                            Review Details
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (ViewBag.TotalPages > 1)

    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= ViewBag.TotalPages; i++)

                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@i"
                           asp-route-status="@Context.Request.Query["status"]"
                           asp-route-themeId="@Context.Request.Query["themeId"]"
                           asp-route-authorId="@Context.Request.Query["authorId"]"
                           asp-route-search="@Context.Request.Query["search"]">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>