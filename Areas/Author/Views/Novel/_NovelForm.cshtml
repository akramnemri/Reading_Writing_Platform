@model Reading_Writing_Platform.ViewModels.NovelFormViewModel

<form method="post" enctype="multipart/form-data" class="space-y-4">
    <div asp-validation-summary="ModelOnly" class="text-red-600 text-sm"></div>

    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="RowVersion" />

    <div>
        <label asp-for="Title" class="block mb-1 text-sm font-medium"></label>
        <input asp-for="Title" class="w-full rounded-[var(--radius-inner)] border border-ink-blue/20 px-3 py-2 bg-white" />
        <span asp-validation-for="Title" class="text-red-600 text-sm"></span>
    </div>

    <div>
        <label asp-for="Description" class="block mb-1 text-sm font-medium"></label>
        <textarea asp-for="Description" rows="5" class="w-full rounded-[var(--radius-inner)] border border-ink-blue/20 px-3 py-2 bg-white"></textarea>
        <span asp-validation-for="Description" class="text-red-600 text-sm"></span>
    </div>

    <div>
        <label asp-for="CoverImageFile" class="block mb-1 text-sm font-medium"></label>
        <input asp-for="CoverImageFile" type="file" accept="image/*" class="w-full rounded-[var(--radius-inner)] border border-ink-blue/20 px-3 py-2 bg-white" />
        <span asp-validation-for="CoverImageFile" class="text-red-600 text-sm"></span>
        @if (!string.IsNullOrWhiteSpace(Model.CoverImageUrl))
        {
            <p class="mt-2 text-xs text-ink-blue/60">Current image:</p>
            <img src="@Model.CoverImageUrl" alt="Current cover" class="mt-1 h-32 w-24 object-cover rounded-[var(--radius-inner)]" />
        }
    </div>

    <div>
        <p class="block mb-1 text-sm font-medium">Themes</p>
        <div class="grid grid-cols-2 gap-2">
            @foreach (var theme in Model.AvailableThemes)
            {
                <label class="flex items-center gap-2 text-sm">
                    <input type="checkbox" name="SelectedThemeIds" value="@theme.Value" checked="@theme.Selected" />
                    <span>@theme.Text</span>
                </label>
            }
        </div>
    </div>

    <div class="flex gap-2">
         <button type="submit" class="btn-primary">Save</button>
        <a asp-action="Index" class="btn-ghost">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}