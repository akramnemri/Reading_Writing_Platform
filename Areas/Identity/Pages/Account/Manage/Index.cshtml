@page
@using Reading_Writing_Platform.Models
@model Reading_Writing_Platform.Areas.Identity.Pages.Account.Manage.IndexModel
@{
    ViewData["Title"] = "Account Dashboard";
    Layout = "/Views/Shared/_Layout.cshtml";
}

<div style="max-width: 1200px; margin: 0 auto; padding: 0 24px;">
    <div style="margin-bottom: 32px;">
        <h1 style="font-size: 28px; font-weight: 700; color: var(--text-heading); font-family: var(--font-heading);">
            Account Dashboard
        </h1>
        <p style="margin-top: 8px; font-size: 14px; color: var(--text-muted);">
            Manage your profile, settings, and preferences.
        </p>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 24px;">
        <!-- Profile Card -->
        <div class="card-book" style="padding: 24px;">
            <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 16px;">
                <div style="width: 64px; height: 64px; border-radius: 50%; overflow: hidden; background: var(--bg-canvas); flex-shrink: 0;">
                    @if (!string.IsNullOrWhiteSpace(Model.ProfilePictureUrl))
                    {
                        <img src="@Model.ProfilePictureUrl" alt="Profile" style="width: 100%; height: 100%; object-fit: cover;" />
                    }
                    else
                    {
                        <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: var(--text-soft);">
                            <svg style="width: 32px; height: 32px;" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                            </svg>
                        </div>
                    }
                </div>
                <div>
                    <h2 style="font-size: 18px; font-weight: 600; color: var(--text-heading);">@Model.DisplayName</h2>
                    <p style="font-size: 14px; color: var(--text-muted);">@Model.Email</p>
                </div>
            </div>
            <p style="font-size: 14px; color: var(--text-muted); margin-bottom: 16px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                @(string.IsNullOrWhiteSpace(Model.Bio) ? "No bio yet." : Model.Bio)
            </p>
            <div style="display: flex; flex-wrap: wrap; gap: 8px;">
                <a asp-page="./SetupProfile" class="btn-ghost" style="padding: 8px 16px; display: inline-block;">
                    Edit Profile
                </a>
                <span style="display: inline-flex; align-items: center; padding: 4px 10px; border-radius: 999px; font-size: 12px; font-weight: 500;
                    @(Model.Intent switch { 
                        ProfileIntent.Read => "background: var(--success-soft); color: var(--success); border: 1px solid var(--success);", 
                        ProfileIntent.Write => "background: var(--info-soft); color: var(--info); border: 1px solid var(--info);", 
                        ProfileIntent.Both => "background: #EDE5FF; color: #6A55B7; border: 1px solid #6A55B7;", 
                        _ => "background: var(--bg-inset); color: var(--text-main); border: 1px solid var(--border);" 
                    })">
                    @Model.Intent
                </span>
            </div>
        </div>

        <!-- Stats Card (if author) -->
        @if (Model.IsAuthor)
        {
            <div class="card-book" style="padding: 24px;">
                <h3 style="font-size: 18px; font-weight: 600; color: var(--text-heading); margin-bottom: 16px;">Your Novels</h3>
                <div style="display: flex; flex-direction: column; gap: 12px;">
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <span style="font-size: 14px; color: var(--text-muted);">Total novels</span>
                        <span style="font-weight: 600;">@Model.TotalNovels</span>
                    </div>
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <span style="font-size: 14px; color: var(--text-muted);">Published</span>
                        <span style="font-weight: 600; color: var(--success);">@Model.PublishedNovels</span>
                    </div>
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <span style="font-size: 14px; color: var(--text-muted);">Drafts</span>
                        <span style="font-weight: 600;">@Model.DraftNovels</span>
                    </div>
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <span style="font-size: 14px; color: var(--text-muted);">Total chapters</span>
                        <span style="font-weight: 600;">@Model.TotalChapters</span>
                    </div>
                </div>
                <a asp-area="Author" asp-controller="Novel" asp-action="Index" class="btn-primary" style="display: block; text-align: center; margin-top: 16px; padding: 10px 18px;">
                    Manage Novels
                </a>
            </div>
        }

        <!-- Security Card -->
        <div class="card-book" style="padding: 24px;">
            <h3 style="font-size: 18px; font-weight: 600; color: var(--text-heading); margin-bottom: 16px;">Security</h3>
            <div style="display: flex; flex-direction: column; gap: 12px;">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                    <div>
                        <p style="font-size: 14px; font-weight: 500; color: var(--text-main);">Password</p>
                        <p style="font-size: 12px; color: var(--text-muted);">••••••••</p>
                    </div>
                    <a asp-page="./ChangePassword" class="btn-ghost" style="padding: 6px 12px; font-size: 12px;">
                        Change
                    </a>
                </div>
            </div>
            <div style="margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--border);">
                <a asp-page="./Logout" class="btn-ghost" style="display: block; text-align: center; padding: 8px 16px; color: var(--danger);">
                    Log out
                </a>
            </div>
        </div>
    </div>
</div>