@page
@model Reading_Writing_Platform.Areas.Identity.Pages.Account.Manage.ChangePasswordModel
@{
    ViewData["Title"] = "Change password";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Reading_Writing_Platform</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="min-h-full bg-cream text-ink-blue font-body antialiased">
    <main class="min-h-screen grid lg:grid-cols-2">
        <section class="flex items-center justify-center px-6 py-10 order-2 lg:order-1">
            <div class="w-full max-w-md rounded-[var(--radius-outer)] border border-ink-blue/10 bg-white/85 p-8 shadow-[0_20px_40px_rgba(26,43,60,0.08)]">
                <h1 class="text-4xl font-display text-deep-navy">Change password</h1>
                <p class="mt-3 text-sm text-ink-blue/70">Update your credentials securely.</p>

                @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
                {
                    <div class="mt-4 rounded-[var(--radius-inner)] border border-antique-gold/30 bg-antique-gold/15 px-3 py-2 text-sm text-deep-navy">
                        @Model.StatusMessage
                    </div>
                }

                <form method="post" class="mt-6 space-y-4">
                    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
                    {
                        <div asp-validation-summary="ModelOnly" class="rounded-[var(--radius-inner)] border border-red-300 bg-red-50 px-3 py-2 text-sm text-red-700"></div>
                    }

                    <div>
                        <label asp-for="Input.OldPassword" class="mb-1 block text-sm font-medium"></label>
                        <input asp-for="Input.OldPassword" autocomplete="current-password" class="w-full rounded-[var(--radius-inner)] border border-ink-blue/20 bg-white px-3 py-2 outline-none transition focus:border-antique-gold" />
                        <span asp-validation-for="Input.OldPassword" class="mt-1 block text-sm text-red-600"></span>
                    </div>

                    <div>
                        <label asp-for="Input.NewPassword" class="mb-1 block text-sm font-medium"></label>
                        <input asp-for="Input.NewPassword" autocomplete="new-password" class="w-full rounded-[var(--radius-inner)] border border-ink-blue/20 bg-white px-3 py-2 outline-none transition focus:border-antique-gold" />
                        <span asp-validation-for="Input.NewPassword" class="mt-1 block text-sm text-red-600"></span>
                    </div>

                    <div>
                        <label asp-for="Input.ConfirmPassword" class="mb-1 block text-sm font-medium"></label>
                        <input asp-for="Input.ConfirmPassword" autocomplete="new-password" class="w-full rounded-[var(--radius-inner)] border border-ink-blue/20 bg-white px-3 py-2 outline-none transition focus:border-antique-gold" />
                        <span asp-validation-for="Input.ConfirmPassword" class="mt-1 block text-sm text-red-600"></span>
                    </div>

                    <button type="submit" class="btn-gold w-full justify-center">Update password</button>
                </form>
            </div>
        </section>

        <section class="relative hidden lg:block order-1 lg:order-2">
            <img src="~/images/auth/change-password.jpg" alt="Change password visual" class="h-full w-full object-cover" />
            <div class="absolute inset-0 bg-gradient-to-t from-deep-navy/85 via-deep-navy/40 to-antique-gold/25"></div>
        </section>
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>