@page
@{
    ViewData["Title"] = "Reset link sent";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Reading_Writing_Platform</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="min-h-full bg-cream text-ink-blue font-body antialiased">
    <main class="min-h-screen flex items-center justify-center px-6">
        <div class="w-full max-w-lg rounded-[var(--radius-outer)] border border-ink-blue/10 bg-white/85 p-8 text-center shadow-[0_20px_40px_rgba(26,43,60,0.08)]">
            <h1 class="text-3xl font-display text-deep-navy">Check your email</h1>
            <p class="mt-3 text-sm text-ink-blue/70">
                If an account exists for that email, a password reset link has been sent.
            </p>
            <a asp-area="Identity" asp-page="/Account/Login" class="btn-primary mt-6">Back to sign in</a>
        </div>
    </main>
</body>
</html>