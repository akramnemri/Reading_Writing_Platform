@model Reading_Writing_Platform.Models.Novel
@using Reading_Writing_Platform.Models

@{
    ViewData["Title"] = Model.Title;
    var chapters = Model.Chapters.OrderBy(c => c.ChapterNumber).ToList();
    int totalWords = chapters.Sum(c => c.WordCount);
}

<div class="space-y-6">
    <nav class="text-sm text-soft flex items-center gap-2">
        <a href="/" class="hover:text-main">Home</a>
        <span>›</span>
        <span class="text-main font-medium">@Model.Title</span>
    </nav>

    @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
    {
        <div class="flex gap-2">
            <a asp-area="Admin" asp-action="Details" asp-controller="Review" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-warning">
                ← Review This Draft
            </a>
            <a asp-area="Admin" asp-action="Index" class="btn btn-sm btn-outline-secondary">
                Review Queue
            </a>
        </div>
    }

    <section class="rounded-lg border border-ink-blue/10 bg-panel p-6 shadow-soft">
        <div class="flex flex-col gap-8 lg:flex-row">
            <!-- Left Column: Cover -->
            <div class="w-full lg:w-72 shrink-0">
                <div class="relative aspect-3/4 w-full overflow-hidden rounded-lg bg-inset">
                    @if (!string.IsNullOrWhiteSpace(Model.CoverImageUrl))
                    {
                        <img src="@Model.CoverImageUrl" alt="@Model.Title cover" class="h-full w-full object-cover" />
                    }
                    else
                    {
                        <div class="flex h-full w-full items-center justify-center px-3 text-center text-xs text-muted">
                            No cover image
                        </div>
                    }
                    @if (chapters.Any())
                    {
                        var latestChapter = chapters.Last();
                        <span class="badge badge-new-episode">NEW EPISODE</span>
                    }
                </div>
            </div>

            <!-- Right Column: Info -->
            <div class="min-w-0 flex-1">
                <div class="flex items-center gap-2 mb-2">
                    @if (Model.Status == NovelStatus.Completed)
                    {
                        <span class="badge badge-completed">Completed</span>
                    }
                    else if (Model.Status == NovelStatus.Published || Model.Status == NovelStatus.Paused)
                    {
                        <span class="badge badge-ongoing">Ongoing</span>
                    }
                </div>

                <h1 class="text-h1 font-heading text-heading">@Model.Title</h1>

                <!-- Rating Row -->
                <div class="rating-badge mt-2">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 4l3 6h6l-5 4 2 6-6-3-6 3 2-6-5-4h6z" />
                    </svg>
                    <span class="font-semibold">89%</span>
                    <svg class="w-4 h-4 text-warning" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 2l3 6h6l-5 4 2 6-6-3-6 3 2-6-5-4h6z" />
                    </svg>
                    <span class="text-xs text-soft">691 Reviews</span>
                </div>

                <!-- Metadata -->
                <div class="mt-4 text-sm text-muted">
                    <p>Author: <span class="text-main font-medium">@(Model.AuthorUser?.UserName ?? "Unknown")</span></p>
                </div>

                <!-- Themes -->
                @if (Model.NovelThemes.Any())
                {
                    <div class="mt-3 flex flex-wrap gap-2">
                        @foreach (var nt in Model.NovelThemes)
                        {
                            <span class="filter-pill">@nt.Theme?.Name</span>
                        }
                    </div>
                }

                <!-- Synopsis -->
                <p class="mt-4 text-sm text-muted leading-relaxed line-clamp-3">
                    @(string.IsNullOrWhiteSpace(Model.Description) ? "No description available." : Model.Description)
                </p>
                <button class="text-accent text-sm mt-1">Show more ▾</button>

                <!-- Word Count -->
                <div class="mt-4 flex gap-4 text-xs text-soft">
                    <span>@chapters.Count Chapters</span>
                    <span>@totalWords Total Words</span>
                </div>

                <!-- Free Chapter Banner -->
                <div class="mt-4 rounded-md bg-accent-tint p-4">
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-2 text-sm">
                            <svg class="w-4 h-4 text-accent" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z" />
                            </svg>
                            <span class="text-muted">1 Free Chapter Every 23 Hrs</span>
                        </div>
                        <a href="#" class="text-accent text-sm font-medium">1 Free Chapter</a>
                    </div>
                </div>

                <!-- CTA -->
                @if (chapters.Any())
                {
                    <div class="mt-5">
                        @if (ViewBag.LastReadChapterNumber != null)
                        {
                            <a asp-controller="PublicNovels"
                               asp-action="ReadChapter"
                               asp-route-slug="@Model.Slug"
                               asp-route-chapterNumber="@ViewBag.LastReadChapterNumber"
                               class="btn-cta-primary w-full text-center block">
                                CONTINUE READING
                            </a>
                            <p class="text-center text-xs text-soft mt-2">Chapter @ViewBag.LastReadChapterNumber — @chapters.First(c => c.ChapterNumber == ViewBag.LastReadChapterNumber)?.Title</p>
                        }
                        else
                        {
                            <a asp-controller="PublicNovels"
                               asp-action="ReadChapter"
                               asp-route-slug="@Model.Slug"
                               asp-route-chapterNumber="@chapters.First().ChapterNumber"
                               class="btn-cta-primary w-full text-center block">
                                START READING
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </section>

    <!-- Tabs -->
    <section class="bg-panel rounded-lg border border-ink-blue/10 p-5">
        <div class="tab-nav">
            <button class="tab-item active">Chapters</button>
            <button class="tab-item">About</button>
        </div>

        <!-- Chapter List -->
        <div class="mt-4">
            @if (!chapters.Any())
            {
                <p class="text-sm text-soft">No chapters published yet.</p>
            }
            else
            {
                <div class="space-y-2">
                    @foreach (var chapter in chapters.Take(20))
                    {
                        <a asp-controller="PublicNovels"
                           asp-action="ReadChapter"
                           asp-route-slug="@Model.Slug"
                           asp-route-chapterNumber="@chapter.ChapterNumber"
                           class="flex items-center justify-between rounded-md border border-ink-blue/10 p-3 hover:bg-inset transition-colors">
                            <div>
                                <p class="font-medium text-main text-sm">
                                    Chapter @chapter.ChapterNumber — @chapter.Title
                                </p>
                                @if (chapter.PublishedAt.HasValue)
                                {
                                    <p class="text-xs text-soft mt-0.5">
                                        Published @chapter.PublishedAt.Value.ToLocalTime().ToString("MMM dd, yyyy")
                                    </p>
                                }
                            </div>
                            <div class="flex items-center gap-3 text-xs text-soft shrink-0">
                                <span>@chapter.WordCount words</span>
                            </div>
                        </a>
                    }
                </div>
            }
        </div>
    </section>
</div>