@model IReadOnlyList<Reading_Writing_Platform.ViewModels.NovelListItemViewModel>

@{
    ViewData["Title"] = "Novel Series";
}

<div class="space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-3xl font-display text-deep-navy">All Novels</h1>
            <p class="mt-2 text-sm text-ink-blue/70">
                Browse our complete collection of published novels.
            </p>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="card-book p-10 text-center">
            <h2 class="text-xl font-display text-deep-navy">No novels published yet</h2>
            <p class="text-sm text-ink-blue/70 mt-2">Check back later for new content.</p>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
            @foreach (var novel in Model)
            {
                <article class="card-book">
                    <div class="aspect-3/4 w-full overflow-hidden bg-paper-grey">
                        @if (!string.IsNullOrWhiteSpace(novel.CoverImageUrl))
                        {
                            <img src="@novel.CoverImageUrl" alt="@novel.Title cover" class="h-full w-full object-cover" />
                        }
                        else
                        {
                            <div class="flex h-full w-full items-center justify-center text-xs text-ink-blue/60">
                                No cover
                            </div>
                        }
                    </div>
                    <div class="p-4">
                        <h3 class="font-display text-deep-navy text-lg font-semibold line-clamp-2">@novel.Title</h3>
                        <p class="text-sm text-ink-blue/70 mt-1 line-clamp-2">
                            @(string.IsNullOrWhiteSpace(novel.Description) ? "No description." : novel.Description)
                        </p>
                        <div class="mt-3 flex items-center justify-between text-xs text-ink-blue/60">
                            <span>@novel.ChapterCount chapters</span>
                        </div>
                        <a asp-controller="PublicNovels" asp-action="Details" asp-route-slug="@novel.Slug" class="btn-ghost w-full mt-3 text-center block">
                            Read Now
                        </a>
                    </div>
                </article>
            }
        </div>
    }
</div>
