@{
    ViewData["Title"] = "My Ebooks";
}

<div class="space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-3xl font-display text-deep-navy">My Ebooks</h1>
            <p class="mt-2 text-sm text-ink-blue/70">
                Ebooks you've purchased or added to your library.
            </p>
        </div>
    </div>

    <div class="card-book p-10 text-center">
        <div class="flex flex-col items-center gap-4">
            <svg class="w-16 h-16 text-soft" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
            <h2 class="text-xl font-display text-deep-navy">No ebooks yet</h2>
            <p class="text-sm text-ink-blue/70 max-w-md">
                Your ebook library will appear here. Purchase or add novels to read them in our beautiful reader.
            </p>
            <a asp-controller="PublicNovels" asp-action="Index" class="btn-primary mt-2">Browse Novels</a>
        </div>
    </div>
</div>
