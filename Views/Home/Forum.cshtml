@{
    ViewData["Title"] = "Community Forum";
}

<div class="space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-3xl font-display text-deep-navy">Community Forum</h1>
            <p class="mt-2 text-sm text-ink-blue/70">
                Discuss novels, share tips, and connect with other readers and writers.
            </p>
        </div>
    </div>

    <div class="card-book p-10 text-center">
        <div class="flex flex-col items-center gap-4">
            <svg class="w-16 h-16 text-soft" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z" />
            </svg>
            <h2 class="text-xl font-display text-deep-navy">Forum coming soon</h2>
            <p class="text-sm text-ink-blue/70 max-w-md">
                Our community forum is under development. Soon you'll be able to discuss your favorite novels, share writing tips, and connect with fellow enthusiasts.
            </p>
        </div>
    </div>
</div>
