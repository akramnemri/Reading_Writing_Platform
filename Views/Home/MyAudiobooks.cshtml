@{
    ViewData["Title"] = "My Audiobooks";
}

<div class="space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-3xl font-display text-deep-navy">My Audiobooks</h1>
            <p class="mt-2 text-sm text-ink-blue/70">
                Audiobooks you've purchased or added to your library.
            </p>
        </div>
    </div>

    <div class="card-book p-10 text-center">
        <div class="flex flex-col items-center gap-4">
            <svg class="w-16 h-16 text-soft" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" />
            </svg>
            <h2 class="text-xl font-display text-deep-navy">No audiobooks yet</h2>
            <p class="text-sm text-ink-blue/70 max-w-md">
                Audiobook support is coming soon. You'll be able to listen to your favorite novels on the go.
            </p>
        </div>
    </div>
</div>
