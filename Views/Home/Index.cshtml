@model Reading_Writing_Platform.ViewModels.HomeIndexViewModel
@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->
<section class="hero">
    <h1 class="hero-title">Welcome to NovelWorld</h1>
    <p class="hero-subtitle">Discover stories, share your voice, and connect with fellow readers and writers.</p>
</section>

<!-- Featured Novels -->
@if (Model.PublishedNovels.Any())
{
    <section class="featured-section">
        <h2 class="section-header">Featured Novels</h2>
        <div class="featured-grid">
            @foreach (var novel in Model.PublishedNovels.Take(6))
            {
                <article class="featured-card">
                    @if (!string.IsNullOrWhiteSpace(novel.CoverImageUrl))
                    {
                        <img src="@novel.CoverImageUrl" alt="@novel.Title cover" class="featured-cover" />
                    }
                    else
                    {
                        <div class="featured-cover-placeholder">No cover</div>
                    }
                    <div class="card-info">
                        <h3 class="card-title">@novel.Title</h3>
                        <p class="card-description">
                            @(string.IsNullOrWhiteSpace(novel.Description) ? "No description." : novel.Description)
                        </p>
                        <a asp-area="" asp-controller="PublicNovels" asp-action="Details" asp-route-slug="@novel.Slug" class="card-link">
                            Read Now →
                        </a>
                    </div>
                </article>
            }
        </div>
    </section>
}