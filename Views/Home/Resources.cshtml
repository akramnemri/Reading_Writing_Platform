@{
    ViewData["Title"] = "Resources";
}

<div class="space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-3xl font-display text-deep-navy">Resources</h1>
            <p class="mt-2 text-sm text-ink-blue/70">
                Helpful guides, community information, and platform documentation.
            </p>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="card-book p-6">
            <h3 class="text-lg font-display text-deep-navy mb-2">Writing Guides</h3>
            <p class="text-sm text-ink-blue/70 mb-4">Tips and techniques for crafting compelling stories and improving your writing.</p>
            <a href="#" class="text-accent text-sm font-medium">Learn more →</a>
        </div>
        <div class="card-book p-6">
            <h3 class="text-lg font-display text-deep-navy mb-2">Community Guidelines</h3>
            <p class="text-sm text-ink-blue/70 mb-4">Our rules and expectations for a welcoming, respectful community.</p>
            <a href="#" class="text-accent text-sm font-medium">Read guidelines →</a>
        </div>
        <div class="card-book p-6">
            <h3 class="text-lg font-display text-deep-navy mb-2">FAQ</h3>
            <p class="text-sm text-ink-blue/70 mb-4">Answers to frequently asked questions about reading, writing, and publishing.</p>
            <a href="#" class="text-accent text-sm font-medium">View FAQ →</a>
        </div>
        <div class="card-book p-6">
            <h3 class="text-lg font-display text-deep-navy mb-2">Support</h3>
            <p class="text-sm text-ink-blue/70 mb-4">Need help? Contact our support team for assistance with any issues.</p>
            <a href="#" class="text-accent text-sm font-medium">Get support →</a>
        </div>
        <div class="card-book p-6">
            <h3 class="text-lg font-display text-deep-navy mb-2">Platform Tour</h3>
            <p class="text-sm text-ink-blue/70 mb-4">A quick walkthrough of all the features available on NovelWorld.</p>
            <a href="#" class="text-accent text-sm font-medium">Start tour →</a>
        </div>
        <div class="card-book p-6">
            <h3 class="text-lg font-display text-deep-navy mb-2">Community Discord</h3>
            <p class="text-sm text-ink-blue/70 mb-4">Join our Discord server to chat with other readers and authors in real time.</p>
            <a href="#" class="text-accent text-sm font-medium">Join Discord →</a>
        </div>
    </div>
</div>
