@model Reading_Writing_Platform.ViewModels.NovelDetailsViewModel
@using Reading_Writing_Platform.Models

@{
    ViewData["Title"] = $"Novel - {Model.Title}";

    string statusBadgeClass = Model.Status switch
    {
        NovelStatus.Published => "bg-emerald-100 text-emerald-800 border border-emerald-200",
        NovelStatus.Draft => "bg-slate-100 text-slate-700 border border-slate-200",
        NovelStatus.Submitted => "bg-amber-100 text-amber-800 border border-amber-200",
        NovelStatus.Approved => "bg-sky-100 text-sky-800 border border-sky-200",
        NovelStatus.Rejected => "bg-rose-100 text-rose-800 border border-rose-200",
        _ => "bg-paper-grey text-ink-blue border border-ink-blue/10"
    };
}

<div class="space-y-6">
    <nav class="text-sm text-ink-blue/60 flex items-center gap-2">
        <a asp-controller="Novel" asp-action="Index" class="hover:text-ink-blue">Dashboard</a>
        <span>›</span>
        <span class="text-ink-blue font-medium">@Model.Title</span>
    </nav>

    @if (TempData["StatusMessage"] is string statusMessage && !string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="rounded-[var(--radius-inner)] border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800">@statusMessage</div>
    }

    <section class="rounded-[var(--radius-outer)] border border-ink-blue/10 bg-white p-6 shadow-[0_10px_24px_rgba(26,43,60,0.06)]">
        <div class="flex flex-col gap-6 md:flex-row">
            <div class="h-52 w-36 shrink-0 overflow-hidden rounded-[var(--radius-inner)] bg-paper-grey">
                @if (!string.IsNullOrWhiteSpace(Model.CoverImageUrl))
                {
                    <img src="@Model.CoverImageUrl" alt="@Model.Title cover" class="h-full w-full object-cover" />
                }
                else
                {
                    <div class="flex h-full w-full items-center justify-center px-3 text-center text-xs text-ink-blue/60">No cover image</div>
                }
            </div>

            <div class="min-w-0 flex-1">
                <div class="flex flex-wrap items-center gap-3">
                    <h1 class="text-4xl font-display text-deep-navy">@Model.Title</h1>
                    <span class="rounded-full px-2.5 py-1 text-xs font-medium @statusBadgeClass">@Model.Status</span>
                </div>

                <p class="mt-3 text-sm text-ink-blue/75 leading-relaxed">
                    @(string.IsNullOrWhiteSpace(Model.Description) ? "No description yet." : Model.Description)
                </p>

                <div class="mt-5 flex flex-wrap gap-2">
                    <a href="@Url.Action("Create", "Chapter", new { novelId = Model.Id, novelSlug = Model.Slug })" class="btn-gold py-2 px-4">+ Create Chapter</a>
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-ghost py-2 px-4">Edit Metadata</a>

                    @if (Model.CanSubmitForReview)
                    {
                        <form asp-action="SubmitForReview" method="post" class="inline">
                            <input type="hidden" name="id" value="@Model.Id" />
                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                            <button type="submit" class="btn-primary py-2 px-4">Submit for Review</button>
                        </form>
                    }
                </div>
            </div>
        </div>
    </section>

    <section class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <article class="card-book"><p class="text-xs uppercase tracking-[0.12em] text-ink-blue/60">Total chapters</p><p class="mt-2 text-3xl font-display text-deep-navy">@Model.TotalChapters</p></article>
        <article class="card-book"><p class="text-xs uppercase tracking-[0.12em] text-ink-blue/60">Published</p><p class="mt-2 text-3xl font-display text-deep-navy">@Model.PublishedChapters</p></article>
        <article class="card-book"><p class="text-xs uppercase tracking-[0.12em] text-ink-blue/60">Reads</p><p class="mt-2 text-3xl font-display text-deep-navy">@(Model.ReadsCount?.ToString() ?? "--")</p></article>
        <article class="card-book"><p class="text-xs uppercase tracking-[0.12em] text-ink-blue/60">Purchases</p><p class="mt-2 text-3xl font-display text-deep-navy">@(Model.PurchasesCount?.ToString() ?? "--")</p></article>
    </section>

    <section class="rounded-[var(--radius-outer)] border border-ink-blue/10 bg-white p-5">
        <div class="mb-4 flex items-center justify-between">
            <h2 class="text-xl font-display text-deep-navy">Chapters</h2>
            <div class="text-xs text-ink-blue/60">Locked / price / status overview</div>
        </div>

        @if (Model.Chapters.Count == 0)
        {
            <p class="text-sm text-ink-blue/60">No chapters yet.</p>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="min-w-full text-sm">
                    <thead class="bg-paper-grey/35 text-ink-blue/70 uppercase text-xs">
                        <tr>
                            <th class="px-4 py-3 text-left">Ch.</th>
                            <th class="px-4 py-3 text-left">Title</th>
                            <th class="px-4 py-3 text-left">Status</th>
                            <th class="px-4 py-3 text-left">Locked</th>
                            <th class="px-4 py-3 text-left">Price</th>
                            <th class="px-4 py-3 text-left">Purchases</th>
                            <th class="px-4 py-3 text-left">Updated</th>
                            <th class="px-4 py-3 text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var chapter in Model.Chapters)
                        {
                            string chapterStatusClass = chapter.Status == ChapterStatus.Published
                                ? "bg-emerald-100 text-emerald-800 border border-emerald-200"
                                : "bg-slate-100 text-slate-700 border border-slate-200";

                            <tr class="border-t border-ink-blue/10">
                                <td class="px-4 py-4 font-medium">@chapter.ChapterNumber</td>
                                <td class="px-4 py-4"><p class="font-medium text-deep-navy">@chapter.Title</p><p class="text-xs text-ink-blue/60">@chapter.WordCount words</p></td>
                                <td class="px-4 py-4"><span class="rounded-full px-2.5 py-1 text-xs font-medium @chapterStatusClass">@chapter.Status</span></td>
                                <td class="px-4 py-4 text-ink-blue/75">@(chapter.IsLocked ? "Yes" : "No")</td>
                                <td class="px-4 py-4 text-ink-blue/75">@(chapter.BasePrice > 0 ? $"{chapter.BasePrice} Coins" : "Free")</td>
                                <td class="px-4 py-4 text-ink-blue/75">@(chapter.PurchasesCount?.ToString() ?? "--")</td>
                                <td class="px-4 py-4 text-ink-blue/70">@chapter.UpdatedAt.ToLocalTime().ToString("g")</td>
                                <td class="px-4 py-4">
                                    <div class="flex justify-end gap-2">
                                        <a href="@Url.Action("Edit", "Chapter", new { novelId = Model.Id, novelSlug = Model.Slug, id = chapter.Id })" class="btn-ghost py-1.5 px-3 text-xs">Edit</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.TotalPages > 1)
            {
                <div class="mt-4 flex flex-wrap items-center justify-between gap-3">
                    <a asp-action="Details" asp-route-id="@Model.Id" asp-route-chapterPage="@(Model.ChapterPage - 1)" asp-route-pageSize="@Model.PageSize" class="btn-ghost py-2 px-4 @(Model.ChapterPage <= 1 ? "pointer-events-none opacity-50" : null)">Previous</a>
                    <div class="flex flex-wrap items-center gap-1 text-sm">
                        @for (int p = 1; p <= Model.TotalPages; p++)
                        {
                            <a asp-action="Details" asp-route-id="@Model.Id" asp-route-chapterPage="@p" asp-route-pageSize="@Model.PageSize" class="@(p == Model.ChapterPage ? "nav-pill nav-pill-active" : "nav-pill")">@p</a>
                        }
                    </div>
                    <a asp-action="Details" asp-route-id="@Model.Id" asp-route-chapterPage="@(Model.ChapterPage + 1)" asp-route-pageSize="@Model.PageSize" class="btn-ghost py-2 px-4 @(Model.ChapterPage >= Model.TotalPages ? "pointer-events-none opacity-50" : null)">Next</a>
                </div>
            }
        }
    </section>
</div>