@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<ul class="flex items-center gap-2">
@if (SignInManager.IsSignedIn(User))
{
    <li>
        <a asp-area="Identity"
           asp-page="/Account/Manage/Index"
           title="Manage account"
           class="nav-pill">
            @User.Identity?.Name
        </a>
    </li>
    <li>
        <form method="post"
              asp-area="Identity"
              asp-page="/Account/Logout"
              asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn-ghost py-2 px-4">Logout</button>
        </form>
    </li>
}
else
{
    <li>
        <a asp-area="Identity" asp-page="/Account/Register" class="btn-ghost py-2 px-4">Register</a>
    </li>
    <li>
        <a asp-area="Identity" asp-page="/Account/Login" class="btn-primary py-2 px-4">Login</a>
    </li>
}
</ul>
